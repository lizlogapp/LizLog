{
  "expo": {
    "name": "蜥日日記",
    "slug": "lizlog",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/branding/logos/logo-image.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/branding/logos/logo-image.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFEFA"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.lizlog.app",
      "adaptiveIcon": {
        "backgroundColor": "#FFFEFA",
        "foregroundImage": "./assets/branding/logos/logo-image.png"
      }
    },
    "web": {
      "favicon": "./assets/branding/logos/logo-image.png"
    },
    "scheme": "lizlog",
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "允許蜥日日記選擇寵物、日記與醫療紀錄照片。"
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#FF7300",
          "defaultChannel": "lizlog-reminders"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f2a5d238-17f4-4dcd-bc8c-94a025f3396a"
      }
    },
    "owner": "asia10445"
  }
}
