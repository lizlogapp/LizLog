{
  "expo": {
    "name": "蜥日日記",
    "slug": "lizlog",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/branding/logos/logo-image-only.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/branding/logos/logo-image-only.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFEFA"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.lizlog.app",
      "adaptiveIcon": {
        "backgroundColor": "#FFFEFA",
        "foregroundImage": "./assets/branding/logos/logo-image-only.png"
      }
    },
    "web": {
      "favicon": "./assets/branding/logos/logo-image-only.png"
    },
    "scheme": "lizlog",
    "plugins": [
      "expo-router",
      "expo-web-browser"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f2a5d238-17f4-4dcd-bc8c-94a025f3396a"
      }
    },
    "owner": "asia10445"
  }
}
